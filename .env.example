# rps-xml-tracker — variáveis de produção (SRVRPS03). Copie para .env (NÃO versionar).

# --- Postgres próprio do tracker ---
POSTGRES_USER=tracker
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=xml_tracker

# --- Auth ---
# DEVE ser EXATAMENTE o mesmo segredo do rps-maestro (SSO: um login só).
MAESTRO_JWT_SECRET=cole-aqui-o-mesmo-MAESTRO_JWT_SECRET-do-maestro
# Segredo HMAC compartilhado com o agente do SRVIMPORT (gere um novo, ex.: openssl rand -hex 32).
TRACKER_AGENT_SECRET=gere-um-segredo-forte

# --- CORS (origem do maestro_web, para a UI chamar a API pelo navegador) ---
TRACKER_CORS_ORIGINS=http://192.168.10.46:3000

# --- Firebird do Athenas (SRVRPS02), usado pelo poller (READ-ONLY) ---
TRACKER_FB_DSN=SYSDBA:masterkey@192.168.10.160:3050/e:\Athenas\rps.fdb?charset=NONE&auth_plugin_name=Legacy_Auth&wire_crypt=disabled
TRACKER_POLL_INTERVAL=30s

# Notas:
# - A API publica na porta 8090 do host (ver docker-compose.yml).
# - O agente (SRVIMPORT) aponta TRACKER_API_URL=http://192.168.10.46:8090 e usa o
#   mesmo TRACKER_AGENT_SECRET. Ele NÃO roda neste compose (é Windows).
